{
  "name": "kb-sync",
  "version": "1.0.0",
  "type": "module",
  "description": "CIC Knowledge Base Sync Pipeline",
  "scripts": {
    "kb:sync": "bash modules/notebooklm/ingest-notebooklm.sh",
    "kb:sync:rollback": "bash modules/notebooklm/ingest-notebooklm.sh --rollback",
    "kb:sync:notebooklm": "bash modules/notebooklm/ingest-notebooklm.sh",
    "kb:sync:notebooklm:rollback": "bash modules/notebooklm/ingest-notebooklm.sh --rollback",
    "kb:sync:obsidian": "bash modules/obsidian/ingest-obsidian.sh",
    "wiki:ingest:obsidian:validate": "bash modules/obsidian/ingest-wiki.sh validate",
    "wiki:ingest:obsidian:prompt": "bash modules/obsidian/ingest-wiki.sh prompt",
    "kb:sync:all": "bash core/run-all.sh",
    "kb:sync:all:rollback": "bash core/run-all.sh --rollback",
    "kb:sync:setup-hook": "node -e \"const fs=require('fs');fs.mkdirSync('.git/hooks',{recursive:true});fs.copyFileSync('scripts/notebooklm/post-commit-hook-example.sh','.git/hooks/post-commit');try{fs.chmodSync('.git/hooks/post-commit',0o755)}catch{}console.log('post-commit hook installed')\"",
    "wiki:ingest": "bash modules/wiki/ingest-wiki.sh",
    "wiki:validate-staging": "node modules/wiki/validate-staging-docs.mjs",
    "wiki:validate-batch": "node modules/wiki/validate-staging-docs.mjs --batch",
    "wiki:validate-report": "node modules/wiki/validate-staging-docs.mjs --batch --json=./.validation-report.json",
    "wiki:validate-notify": "node modules/wiki/validate-staging-docs.mjs --batch --json=./.validation-report.json",
    "wiki:dashboard": "open modules/wiki/dashboard.html || start modules/wiki/dashboard.html || xdg-open modules/wiki/dashboard.html",
    "wiki:dashboard:serve": "npx http-server modules/wiki -p 8080 -o dashboard.html -c-1",
    "wiki:cleanup-archives": "node modules/wiki/cleanup-staging-archives.mjs",
    "wiki:cleanup-archives:dry-run": "node modules/wiki/cleanup-staging-archives.mjs --dry-run",
    "wiki:cleanup-archives:verbose": "node modules/wiki/cleanup-staging-archives.mjs --verbose",
    "artifact:generate": "bash modules/artifact-generator/generate.sh configs/artifact-generator.yaml notebooklm",
    "artifact:generate:obsidian": "bash modules/artifact-generator/generate.sh configs/artifact-generator.yaml obsidian",
    "artifact:generate:all": "bash modules/artifact-generator/generate.sh configs/artifact-generator.yaml notebooklm && bash modules/artifact-generator/generate.sh configs/artifact-generator.yaml obsidian",
    "test:notebooklm": "npx tsx tests/notebooklm-sync-verification.ts",
    "test:core": "npx tsx tests/core-scripts-verification.ts",
    "test:obsidian": "npx tsx tests/obsidian-sync-verification.ts",
    "test:v12-features": "npx tsx tests/validate-staging-v12-features.ts",
    "test:all": "npm run test:core && npm run test:obsidian && npm run test:notebooklm && npm run test:v12-features",
    "wiki:setup-hook": "node -e \"const fs=require('fs');fs.mkdirSync('.git/hooks',{recursive:true});fs.copyFileSync('scripts/wiki-validate-precommit.sh','.git/hooks/pre-commit');try{fs.chmodSync('.git/hooks/pre-commit',0o755)}catch{}console.log('pre-commit hook installed')\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "js-yaml": "^4.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
